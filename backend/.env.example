# Allowed CORS origins (comma-separated). Leave empty when using nginx proxy.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# PostgreSQL connection string.
# For local dev without Docker, leave unset to fall back to SQLite.
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+psycopg2://litmap:litmap_secret@localhost:5432/literature_map
